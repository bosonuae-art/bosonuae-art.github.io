---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import Section from "@/components/Section.astro";
import Button from "@/components/Button.astro";
import CreditGrid from "@/components/CreditGrid.astro";
import Representation from "@/components/Representation.astro";
import InstagramStrip from "@/components/InstagramStrip.astro";
import ContactDetails from "@/components/ContactDetails.astro";
import { site } from "@/data/site";
import { colorFor } from "@/data/gallery";
import hero from "@/assets/portraits/hero-leather.jpg";

// ── In-color reel ──────────────────────────────────────────────────────────
// A curated run of his work, ordered by hue so scrolling flows through a
// deliberate color arc: crimson → red → burnt orange → gold → olive → teal →
// purple. Each figure carries data-accent-color, so as it reaches the viewport
// center the accent engine (BaseLayout) eases the whole site — accent + ambient
// wash — into that photo's color. Reorder this array to change the journey.
import reelRedPortrait from "@/assets/portraits/editorial-red-portrait.jpg";
import reelRedChains from "@/assets/portraits/editorial-red-chains.jpg";
import reelStudioChains from "@/assets/portraits/studio-chains-1.jpg";
import reelGold from "@/assets/portraits/conceptual-gold-1.jpg";
import reelLeather from "@/assets/portraits/studio-leather.jpg";
import reelTeal from "@/assets/portraits/conceptual-gold-2.jpg";
import reelRunway from "@/assets/portraits/fashion-week-1.jpg";

const reel = [
  { src: reelRedPortrait, file: "editorial-red-portrait.jpg", label: "Editorial",
    alt: "Close, dramatic portrait of Jett Williams with chains lit against deep red." },
  { src: reelRedChains, file: "editorial-red-chains.jpg", label: "Editorial",
    alt: "Jett Williams in black with layered chains against a deep red backdrop." },
  { src: reelStudioChains, file: "studio-chains-1.jpg", label: "Studio",
    alt: "Shirtless studio portrait of Jett Williams with silver chains, arm raised, on black." },
  { src: reelGold, file: "conceptual-gold-1.jpg", label: "Conceptual",
    alt: "Jett Williams in gold body paint standing in water at sunset." },
  { src: reelLeather, file: "studio-leather.jpg", label: "Studio",
    alt: "Low-key studio portrait of Jett Williams in a studded leather jacket." },
  { src: reelTeal, file: "conceptual-gold-2.jpg", label: "Conceptual",
    alt: "Gold-painted figure in water, arm bent and head lowered." },
  { src: reelRunway, file: "fashion-week-1.jpg", label: "Fashion Week",
    alt: "Jett Williams walking the runway at Dallas Fashion Week, Day 1 2026." },
].map((r, i) => ({ ...r, color: colorFor(r.file), n: String(i + 1).padStart(2, "0") }));
---

<BaseLayout
  title={`${site.name} — ${site.role}`}
  description={site.about.tagline}
>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero__media">
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        webkit-playsinline
        preload="auto"
        poster="/videos/hero-poster.jpg"
      >
        <source src="/videos/hero.mp4" type="video/mp4" />
      </video>
      <Image
        src={hero}
        alt={`${site.name}, ${site.role}`}
        class="hero__img hero__img--fallback"
        widths={[768, 1200, 1600, 2000]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero__scrim"></div>
    </div>

    <div class="hero__content container-wide">
      <p class="eyebrow hero__eyebrow">{site.role}</p>
      <h1 class="hero__name">Jett<span>Williams</span></h1>
      <p class="hero__tagline text-pretty">{site.about.tagline}</p>
      <div class="hero__cta">
        <Button href="/contact">Book Now</Button>
        <Button href="/portfolio" variant="ghost">View Portfolio</Button>
      </div>
    </div>

    <a href="#approach" class="hero__scroll" aria-label="Scroll to content">
      <span></span>
    </a>
  </section>

  <!-- ── Approach / stats ─────────────────────────────────── -->
  <section id="approach" class="approach">
    <div class="container-content approach__inner">
      <div class="approach__lede reveal">
        <p class="eyebrow">Approach</p>
        <h2 class="approach__title">{site.qualityHeading}</h2>
        <p class="approach__body text-pretty">{site.taglineHero}</p>
      </div>
      <div class="stats reveal">
        {site.homeStats.map((s) => (
          <div class="stat">
            <span class="stat__num">{s.num}</span>
            <span class="stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
    <p class="container-content approach__stat-note reveal">{site.homeStatNote}</p>
  </section>

  <!-- ── In-color reel (scroll = color journey) ───────────── -->
  <section class="reel" aria-label="Selected work, in color">
    <div class="reel__intro container-content reveal">
      <p class="eyebrow">In Color</p>
      <h2 class="reel__title">A spectrum of work</h2>
      <p class="reel__lede text-pretty">
        Keep scrolling — the site takes on the color of each frame, shot for shot.
      </p>
    </div>
    <div class="reel__track">
      {
        reel.map((r) => (
          <figure class="reel__item reveal" data-accent-color={r.color} style={`--c:${r.color}`}>
            <Image
              src={r.src}
              alt={r.alt}
              widths={[600, 900, 1240]}
              sizes="(min-width:900px) 55vw, 82vw"
              class="reel__img"
              loading="lazy"
            />
            <figcaption class="reel__tag">
              <span class="reel__n">{r.n}</span>
              {r.label}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <!-- ── Featured credits ─────────────────────────────────── -->
  <Section eyebrow="Featured By" title="Selected screen & runway credits" id="credits">
    <CreditGrid />
  </Section>

  <!-- ── Representation ───────────────────────────────────── -->
  <Section eyebrow="Representation" title="Represented worldwide">
    <Representation />
  </Section>

  <!-- ── Instagram ────────────────────────────────────────── -->
  <Section eyebrow="Follow The Adventure" title="On set & on the move">
    <InstagramStrip />
  </Section>

  <!-- ── Contact ──────────────────────────────────────────── -->
  <section class="cta">
    <div class="container-content cta__inner reveal">
      <div>
        <p class="eyebrow">Contact the Team</p>
        <h2 class="cta__title">Available for domestic & international bookings.</h2>
        <div class="cta__btn"><Button href="/contact">Book Now</Button></div>
      </div>
      <ContactDetails />
    </div>
  </section>

  <!-- ── Quote ────────────────────────────────────────────── -->
  <figure class="quote reveal">
    <blockquote class="container-content">“{site.franklinQuote.text}”</blockquote>
    <figcaption class="container-content">— {site.franklinQuote.source}</figcaption>
  </figure>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 28%;
  }
  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 30%;
  }
  /* Motion on every screen size, including mobile. The still portrait is shown
     only when the visitor prefers reduced motion. (video is muted + playsinline
     so it autoplays on iOS/Android.) */
  .hero__img--fallback {
    display: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__video {
      display: none;
    }
    .hero__img--fallback {
      display: block;
    }
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(10, 10, 10, 0.55) 0%, transparent 22%, transparent 45%, rgba(10, 10, 10, 0.85) 92%, var(--bg) 100%),
      linear-gradient(90deg, rgba(10, 10, 10, 0.6) 0%, transparent 55%);
  }
  .hero__content {
    position: relative;
    z-index: 1;
    padding-bottom: clamp(3rem, 8vh, 6rem);
    padding-top: 6rem;
  }
  .hero__eyebrow {
    margin-bottom: 1rem;
  }
  .hero__name {
    display: flex;
    flex-direction: column;
    font-size: clamp(72px, 16vw, 220px);
    line-height: 0.82;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 0;
  }
  .hero__name span {
    color: var(--accent);
  }
  .hero__tagline {
    margin-top: 1.75rem;
    max-width: 44ch;
    font-size: clamp(16px, 2.2vw, 20px);
    color: var(--muted);
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.25rem;
  }
  .hero__scroll {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    width: 26px;
    height: 42px;
    border: 1px solid var(--line);
    border-radius: 999px;
    display: none;
  }
  .hero__scroll span {
    position: absolute;
    top: 8px;
    left: 50%;
    width: 3px;
    height: 7px;
    margin-left: -1.5px;
    border-radius: 2px;
    background: var(--accent);
    animation: scroll-cue 1.8s ease-in-out infinite;
  }
  @keyframes scroll-cue {
    0%, 100% { opacity: 0; transform: translateY(0); }
    30% { opacity: 1; }
    60% { opacity: 1; transform: translateY(12px); }
  }
  @media (min-width: 880px) {
    .hero__scroll { display: block; }
  }

  /* Approach + stats */
  .approach {
    padding-block: clamp(4rem, 9vw, 8rem);
  }
  .approach__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  .approach__title {
    font-size: clamp(32px, 5vw, 60px);
    margin-top: 0.75rem;
    max-width: 16ch;
  }
  .approach__body {
    margin-top: 1.5rem;
    max-width: 52ch;
    color: var(--muted);
    font-size: 18px;
  }
  .stats {
    display: flex;
    gap: 2.5rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--accent);
    flex: 1;
  }
  .stat__num {
    font-family: var(--font-display);
    font-size: clamp(44px, 7vw, 72px);
    line-height: 1;
    color: var(--text);
  }
  .stat__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .approach__stat-note {
    margin-top: 2.5rem;
    max-width: 70ch;
    font-size: 14px;
    color: var(--muted);
  }
  @media (min-width: 900px) {
    .approach__inner {
      grid-template-columns: 1.3fr 1fr;
      gap: 5rem;
    }
  }

  /* In-color reel — the scroll-driven color journey */
  .reel {
    padding-block: clamp(4rem, 10vw, 9rem);
    border-top: 1px solid var(--line);
    overflow: hidden;
  }
  .reel__intro {
    max-width: 46ch;
    margin-bottom: clamp(2.5rem, 6vw, 5rem);
  }
  .reel__title {
    font-size: clamp(32px, 5vw, 60px);
    margin-top: 0.75rem;
  }
  .reel__lede {
    margin-top: 1.25rem;
    color: var(--muted);
    font-size: 18px;
    max-width: 40ch;
  }
  .reel__track {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(4rem, 12vh, 9rem);
  }
  .reel__item {
    position: relative;
    width: min(600px, 82vw);
    margin: 0;
    border-radius: 4px;
    overflow: hidden;
    /* each frame radiates its own extracted color (--c) */
    box-shadow: 0 40px 130px -55px var(--c, transparent);
  }
  .reel__img {
    width: 100%;
    height: auto;
    display: block;
  }
  .reel__tag {
    position: absolute;
    left: 0.85rem;
    bottom: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
    background: color-mix(in oklab, var(--c) 22%, rgba(0, 0, 0, 0.6));
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--c) 45%, transparent);
    backdrop-filter: blur(4px);
  }
  .reel__n {
    color: color-mix(in oklab, var(--c) 70%, white);
  }
  /* Gentle zigzag on wide screens so the column has rhythm. */
  @media (min-width: 900px) {
    .reel__item:nth-child(odd) {
      align-self: flex-start;
      margin-left: clamp(0px, 7vw, 8rem);
    }
    .reel__item:nth-child(even) {
      align-self: flex-end;
      margin-right: clamp(0px, 7vw, 8rem);
    }
  }

  /* Contact CTA */
  .cta {
    padding-block: clamp(4rem, 9vw, 8rem);
    border-top: 1px solid var(--line);
  }
  .cta__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .cta__title {
    font-size: clamp(28px, 4.5vw, 46px);
    max-width: 16ch;
    margin-top: 0.75rem;
  }
  .cta__btn {
    margin-top: 2rem;
  }
  @media (min-width: 860px) {
    .cta__inner {
      grid-template-columns: 1.2fr 1fr;
      gap: 5rem;
    }
  }

  /* Quote */
  .quote {
    padding-block: clamp(4rem, 9vw, 7rem);
    border-top: 1px solid var(--line);
  }
  .quote blockquote {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 56px);
    line-height: 1.12;
    color: var(--text);
    margin: 0;
    max-width: 20ch;
  }
  .quote figcaption {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
</style>
