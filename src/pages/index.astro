---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site";
---

<BaseLayout title={`${site.name} — ${site.role}`} description={site.about.tagline}>
  <section class="container-content" style="padding-top:8rem;padding-bottom:6rem;">
    <p class="eyebrow reveal">Scaffold OK</p>
    <h1 class="font-display text-accent reveal" style="font-size:clamp(48px,8vw,96px);margin-top:0.5rem;">
      {site.nickname}
    </h1>
    <p class="text-muted reveal" style="max-width:60ch;margin-top:1rem;">
      Layout, nav, and footer wired. Home page lands in Task 6.
    </p>
  </section>
</BaseLayout>
