---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import Button from "@/components/Button.astro";
import ContactDetails from "@/components/ContactDetails.astro";
import { site } from "@/data/site";
import { colorFor } from "@/data/gallery";
import portrait from "@/assets/portraits/about-portrait.jpg";

const { about } = site;
const portraitColor = colorFor("about-portrait.jpg");
---

<BaseLayout title={`About — ${site.name}`} description={about.tagline}>
  <header class="ah container-content">
    <p class="eyebrow reveal">About</p>
    <h1 class="ah__title reveal">{about.heading}</h1>
    <p class="ah__tag reveal text-pretty">{about.tagline}</p>
  </header>

  <div class="container-content ab">
    <div class="ab__media reveal" data-accent-color={portraitColor}>
      <Image
        src={portrait}
        alt={`${site.name}, ${site.role}`}
        widths={[500, 800]}
        sizes="(min-width:900px) 40vw, 90vw"
        class="ab__img"
        loading="lazy"
      />
      <ul class="ab__stats">
        {about.stats.map((s) => <li class="chip">{s}</li>)}
      </ul>
    </div>

    <div class="ab__prose reveal">
      {about.paragraphs.map((p) => <p>{p}</p>)}

      <div class="ab__interests">
        <p class="eyebrow">Off set</p>
        <ul>
          {about.interests.map((it) => <li>{it}</li>)}
        </ul>
      </div>
    </div>
  </div>

  <section class="ab-specs">
    <div class="container-content ab-specs__grid">
      <div class="ab-specs__col reveal">
        <p class="eyebrow">Specifications</p>
        <dl class="specs">
          {site.measurements.map((m) => (
            <div class="specs__row">
              <dt class="specs__label">{m.label}</dt>
              <dd class="specs__val">{m.value || "—"}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="ab-specs__col reveal">
        <p class="eyebrow">Special skills</p>
        <div class="skills">
          {site.skills.map((g) => (
            <div class="skills__group">
              <h3 class="skills__heading">{g.group}</h3>
              <ul class="skills__list">
                {g.items.map((it) => <li class="chip">{it}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <div class="ab-specs__col reveal">
        <p class="eyebrow">Training</p>
        <ul class="training">
          {site.training.map((t) => (
            <li class="training__item">
              <span class="training__title">{t.title}</span>
              <span class="training__org">{t.org}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="ab-credits">
    <div class="container-content reveal">
      <p class="eyebrow">Selected credits</p>
      <h2 class="ab-credits__title">Screen &amp; runway</h2>
      <ul class="credits-list">
        {site.screenCredits.map((c) => (
          <li class="credit">
            <div class="credit__head">
              <span class="credit__title">{c.title}</span>
              <span class="credit__detail">{c.detail}</span>
            </div>
            <div class="credit__meta">
              <span class="credit__role">{c.role}</span>
              {c.director && <span class="credit__dir">Dir. {c.director}</span>}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="ab-avail">
    <div class="container-content reveal">
      <p class="ab-avail__text text-balance">{about.availability}</p>
      <div class="ab-avail__btn"><Button href="/contact">Book Now</Button></div>
    </div>
  </section>

  <section class="ab-cta">
    <div class="container-content ab-cta__inner reveal">
      <div>
        <p class="eyebrow">Contact the Team</p>
        <h2 class="ab-cta__title">Let's talk about your production.</h2>
      </div>
      <ContactDetails />
    </div>
  </section>
</BaseLayout>

<style>
  .ah {
    padding-top: clamp(7rem, 14vh, 10rem);
    padding-bottom: 3rem;
  }
  .ah__title {
    font-size: clamp(40px, 7vw, 84px);
    line-height: 0.95;
    margin: 0.5rem 0 0;
    max-width: 14ch;
  }
  .ah__tag {
    margin-top: 1.5rem;
    max-width: 44ch;
    color: var(--muted);
    font-size: 18px;
  }
  .ab {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-bottom: clamp(3rem, 8vw, 6rem);
  }
  .ab__media {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .ab__img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--line);
  }
  .ab__stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .ab__prose p {
    color: var(--muted);
    font-size: 17px;
    line-height: 1.75;
    margin: 0 0 1.4rem;
    max-width: 62ch;
  }
  .ab__prose p:first-child::first-letter {
    font-family: var(--font-display);
    font-size: 3.6em;
    line-height: 0.8;
    float: left;
    margin: 0.05em 0.12em 0 0;
    color: var(--accent);
  }
  .ab__interests {
    margin-top: 2.5rem;
  }
  .ab__interests ul {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }
  .ab__interests li {
    font-size: 15px;
    color: var(--text);
    padding-left: 1rem;
    position: relative;
  }
  .ab__interests li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .ab-avail {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-top: 1px solid var(--line);
  }
  .ab-avail__text {
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 40px);
    line-height: 1.2;
    color: var(--text);
    max-width: 26ch;
  }
  .ab-avail__btn {
    margin-top: 2rem;
  }
  .ab-cta {
    padding-block: clamp(4rem, 9vw, 7rem);
    border-top: 1px solid var(--line);
  }
  .ab-cta__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .ab-cta__title {
    font-size: clamp(28px, 4.5vw, 44px);
    max-width: 14ch;
    margin-top: 0.75rem;
  }

  /* Casting specs — measurements, skills, training */
  .ab-specs {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-top: 1px solid var(--line);
  }
  .ab-specs__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .specs {
    margin: 1.5rem 0 0;
  }
  .specs__row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--line);
  }
  .specs__label {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .specs__val {
    margin: 0;
    font-size: 15px;
    color: var(--text);
    text-align: right;
  }
  .skills {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .skills__heading {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text);
  }
  .skills__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .training {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .training__item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-left: 1rem;
    position: relative;
  }
  .training__item::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .training__title {
    font-size: 15px;
    color: var(--text);
  }
  .training__org {
    font-size: 13px;
    color: var(--muted);
  }

  /* Selected credits */
  .ab-credits {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-top: 1px solid var(--line);
  }
  .ab-credits__title {
    font-size: clamp(28px, 4.5vw, 44px);
    margin: 0.5rem 0 2rem;
  }
  .credits-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .credit {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.4rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--line);
  }
  .credit:last-child {
    border-bottom: 1px solid var(--line);
  }
  .credit__head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .credit__title {
    font-family: var(--font-display);
    font-size: clamp(20px, 3vw, 28px);
    letter-spacing: 0.02em;
    color: var(--text);
  }
  .credit__detail {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .credit__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    font-size: 15px;
    color: var(--muted);
  }
  .credit__dir {
    color: var(--text);
  }
  @media (min-width: 760px) {
    .credit {
      grid-template-columns: 1fr 1.4fr;
      align-items: baseline;
      gap: 2rem;
    }
  }
  @media (min-width: 900px) {
    .ab-specs__grid {
      grid-template-columns: 0.9fr 1.35fr 1fr;
      gap: 4rem;
    }
  }
  @media (min-width: 900px) {
    .ab {
      grid-template-columns: 0.85fr 1.15fr;
      gap: 4.5rem;
      align-items: start;
    }
    .ab__media {
      position: sticky;
      top: 92px;
    }
  }
  @media (min-width: 860px) {
    .ab-cta__inner {
      grid-template-columns: 1.2fr 1fr;
      gap: 5rem;
    }
  }
</style>
