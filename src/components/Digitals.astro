---
import { Image } from "astro:assets";
import { digitals } from "@/data/gallery";
---

<section class="digitals container-content reveal" aria-label="Digitals">
  <header class="digitals__head">
    <div>
      <p class="eyebrow">Digitals</p>
      <h2 class="digitals__title">Clean &amp; current.</h2>
    </div>
    <p class="digitals__note">
      Reference frames — front, portrait, and physique. Full unretouched digitals and
      current sizes are available on request.
    </p>
  </header>

  <ul class="digitals__grid">
    {
      digitals.map((d) => (
        <li class="digitals__cell">
          <Image
            src={d.src}
            alt={d.alt}
            widths={[300, 500]}
            sizes="(min-width:640px) 30vw, 45vw"
            class="digitals__img"
            loading="lazy"
          />
        </li>
      ))
    }
  </ul>
</section>

<style>
  .digitals {
    padding-block: clamp(3rem, 7vw, 5rem);
    border-top: 1px solid var(--line);
  }
  .digitals__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .digitals__title {
    font-size: clamp(28px, 4.5vw, 46px);
    margin-top: 0.75rem;
  }
  .digitals__note {
    max-width: 46ch;
    color: var(--muted);
    font-size: 15px;
  }
  .digitals__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .digitals__cell {
    aspect-ratio: 3 / 4;
    border-radius: 3px;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--line);
  }
  .digitals__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (min-width: 640px) {
    .digitals__grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .digitals__head {
      grid-template-columns: 1fr 1fr;
      align-items: end;
    }
  }
</style>
