---
import { site } from "@/data/site";

const telUS = site.phoneUS.replace(/[^+\d]/g, "");
const telIntl = site.phoneIntl.replace(/[^+\d]/g, "");
---

<footer class="footer">
  <div class="container-content footer__inner">
    <div class="footer__brand">
      <span class="footer__mark">{site.nickname}</span>
      <p class="footer__role">{site.role}</p>
    </div>

    <div class="footer__col">
      <p class="eyebrow">Book Now</p>
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <a href={`tel:${telUS}`}>{site.phoneUS}</a>
      <a href={`tel:${telIntl}`}>{site.phoneIntl}</a>
    </div>

    <div class="footer__col">
      <p class="eyebrow">Locations</p>
      {site.locations.map((l) => <span class="footer__muted">{l}</span>)}
      <a href={site.instagram.url} target="_blank" rel="noopener" class="footer__ig"
        >{site.instagram.handle}</a
      >
    </div>
  </div>

  <div class="container-content footer__base">
    <span>{site.copyright}</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    margin-top: 6rem;
    padding-top: 4rem;
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer__mark {
    font-family: var(--font-display);
    font-size: 40px;
    color: var(--text);
  }
  .footer__role {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.25rem;
  }
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer__col a:hover {
    color: var(--accent);
  }
  .footer__muted {
    color: var(--muted);
    font-size: 14px;
  }
  .footer__ig {
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
  }
  .footer__base {
    padding: 1.5rem 0 2.5rem;
    border-top: 1px solid var(--line);
    font-size: 12px;
    color: var(--muted);
  }
  @media (min-width: 720px) {
    .footer__inner {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }
</style>
