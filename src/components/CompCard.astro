---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { Download } from "@/data/site";

interface Props {
  item: Download;
  preview?: ImageMetadata;
}
const { item, preview } = Astro.props;
---

<article class="cc reveal">
  <div class="cc__media">
    {
      preview ? (
        <Image src={preview} alt={`${item.label} preview`} widths={[400, 700]} sizes="(min-width:900px) 30vw, 90vw" class="cc__img" loading="lazy" />
      ) : (
        <span class="cc__placeholder">{item.label.charAt(0)}</span>
      )
    }
  </div>
  <div class="cc__body">
    <h3 class="cc__title">{item.label}</h3>
    {item.note && <p class="cc__note">{item.note}</p>}
    <a
      class="cc__link"
      href={item.file}
      {...item.external ? { target: "_blank", rel: "noopener noreferrer" } : { download: true }}
    >
      {item.external ? "Open ↗" : "Download PDF ↓"}
    </a>
  </div>
</article>

<style>
  .cc {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
  }
  .cc__media {
    aspect-ratio: 3 / 4;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--surface) 60%, black);
    overflow: hidden;
  }
  .cc__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
  .cc__placeholder {
    font-family: var(--font-display);
    font-size: 64px;
    color: var(--muted);
  }
  .cc__body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.5rem;
  }
  .cc__title {
    font-size: 20px;
  }
  .cc__note {
    font-size: 13px;
    color: var(--muted);
    margin: 0;
  }
  .cc__link {
    margin-top: 0.9rem;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .cc__link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
