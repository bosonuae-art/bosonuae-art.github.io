---
import { site } from "@/data/site";
---

<ul class="credits">
  {
    site.credits.map((c) => (
      <li class="credit reveal">
        <div class="credit__media">
          {c.img ? (
            <img
              src={c.img}
              alt={`${c.name} — ${c.work}`}
              class:list={[c.logo ? "credit__logo" : "credit__cover"]}
              loading="lazy"
              decoding="async"
            />
          ) : (
            <span class="credit__mark">{c.name.charAt(0)}</span>
          )}
        </div>
        <div class="credit__meta">
          <span class="credit__name">{c.name}</span>
          <span class="credit__work">{c.work}</span>
        </div>
      </li>
    ))
  }
</ul>

<style>
  .credits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .credit {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .credit__media {
    aspect-ratio: 16 / 10;
    display: grid;
    place-items: center;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 3px;
    overflow: hidden;
  }
  .credit__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Brand wordmarks: normalize any logo to a clean white silhouette so it
     reads on the dark card (fixes black-on-dark logos like Supercuts). */
  .credit__logo {
    max-width: 72%;
    max-height: 52%;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.82;
  }
  .credit__mark {
    font-family: var(--font-display);
    font-size: 40px;
    color: var(--muted);
  }
  .credit__meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .credit__name {
    font-size: 15px;
    color: var(--text);
  }
  .credit__work {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  @media (min-width: 640px) {
    .credits {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .credits {
      grid-template-columns: repeat(6, 1fr);
    }
  }
</style>
